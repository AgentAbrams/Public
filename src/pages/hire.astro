---
// Standalone hire/portfolio page — own layout, own design system
// No imports from BlogLayout or global.css
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Hire Agent Abrams — Senior Full Stack Developer</title>
  <meta name="description" content="Senior full-stack developer specializing in AI-powered automation, React/Next.js, Node.js, e-commerce platforms, and production systems. Top 3% on Toptal." />
  <meta name="author" content="Agent Abrams" />

  <!-- Open Graph -->
  <meta property="og:title" content="Hire Agent Abrams — Senior Full Stack Developer" />
  <meta property="og:description" content="I build production systems that replace entire dev teams. AI-powered automation, full-stack applications, and e-commerce platforms." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://goodquestion.ai/hire" />
  <meta property="og:site_name" content="Agent Abrams" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@agentabrams" />
  <meta name="twitter:title" content="Hire Agent Abrams — Senior Full Stack Developer" />
  <meta name="twitter:description" content="I build production systems that replace entire dev teams. AI-powered automation, full-stack applications, and e-commerce platforms." />

  <link rel="canonical" href="https://goodquestion.ai/hire" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Playfair+Display:wght@700;800;900&display=swap" rel="stylesheet" />

  <style>
    /* =========================================
       RESET & BASE
       ========================================= */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #F5F0EB;
      --forest: #2C3E2D;
      --brass: #C9A96E;
      --text: #1A1A18;
      --text-secondary: #6B6560;
      --terracotta: #D4613A;
      --white: #FFFFFF;
      --black: #111110;
      --display: 'Playfair Display', serif;
      --body: 'DM Sans', sans-serif;
      --accent-serif: 'Cormorant Garamond', serif;
    }

    /* =========================================
       SKIP NAV
       ========================================= */
    .skip-nav {
      position: absolute;
      top: -100%;
      left: 16px;
      z-index: 10000;
      background: var(--forest);
      color: var(--white);
      font-family: var(--body);
      font-weight: 600;
      font-size: 1rem;
      padding: 12px 24px;
      border-radius: 0 0 8px 8px;
      text-decoration: none;
      transition: top 0.2s;
    }

    .skip-nav:focus {
      top: 0;
    }

    html {
      scroll-behavior: smooth;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* =========================================
       REDUCED MOTION
       ========================================= */
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
        scroll-behavior: auto !important;
      }
      .hero-stats-card,
      .hero-stats-card:hover,
      .inquiry-form-card,
      .inquiry-form-card:hover,
      .skill-card:hover,
      .project-featured:hover,
      .project-card:hover,
      .claude-card:hover,
      .shopify-card:hover,
      .service-card:hover {
        transform: none !important;
      }
    }

    body {
      font-family: var(--body);
      font-weight: 400;
      color: var(--text);
      background-color: var(--bg);
      font-size: 17px;
      line-height: 1.7;
      position: relative;
      overflow-x: hidden;
    }

    /* Grain texture overlay */
    body::before {
      content: '';
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      pointer-events: none;
      z-index: 9999;
      opacity: 0.035;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      background-repeat: repeat;
      background-size: 180px 180px;
    }

    a { text-decoration: none; color: inherit; }
    ul, ol { list-style: none; }
    img { max-width: 100%; display: block; }
    button, input, select, textarea { font-family: inherit; font-size: inherit; }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
    }

    .section-label {
      font-family: var(--accent-serif);
      font-style: italic;
      font-weight: 400;
      color: var(--brass);
      font-size: 0.95rem;
      letter-spacing: 0.06em;
      margin-bottom: 8px;
    }

    .section-title {
      font-family: var(--display);
      font-weight: 900;
      font-size: 3rem;
      color: var(--text);
      line-height: 1.1;
      margin-bottom: 24px;
    }

    /* =========================================
       NAV
       ========================================= */
    .nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 1000;
      background: rgba(245, 240, 235, 0.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(201, 169, 110, 0.15);
      padding: 0 24px;
    }

    .nav-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 64px;
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .nav-logo-circle {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      background: var(--forest);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--brass);
      font-family: var(--display);
      font-weight: 900;
      font-size: 1.15rem;
    }

    .nav-logo-text {
      font-family: var(--body);
      font-weight: 600;
      font-size: 0.875rem;
      letter-spacing: 0.12em;
      color: var(--text);
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 32px;
    }

    .nav-link {
      font-family: var(--body);
      font-weight: 500;
      font-size: 0.875rem;
      letter-spacing: 0.08em;
      color: var(--text-secondary);
      transition: color 0.3s;
      padding: 8px 4px;
      min-height: 44px;
      display: inline-flex;
      align-items: center;
    }

    .nav-link:hover { color: var(--forest); }

    .nav-link:focus-visible {
      outline: 3px solid var(--forest);
      outline-offset: 2px;
      border-radius: 4px;
      color: var(--forest);
    }

    .nav-cta {
      font-family: var(--body);
      font-weight: 600;
      font-size: 0.875rem;
      letter-spacing: 0.08em;
      color: var(--white);
      background: var(--forest);
      padding: 12px 24px;
      min-height: 44px;
      border-radius: 6px;
      transition: background 0.3s, transform 0.3s;
      border: none;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
    }

    .nav-cta:hover { background: #1e2d1f; transform: translateY(-1px); }

    .nav-cta:focus-visible {
      outline: 3px solid var(--brass);
      outline-offset: 2px;
    }

    /* Mobile hamburger */
    .nav-hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 10px;
      min-width: 44px;
      min-height: 44px;
      align-items: center;
      justify-content: center;
      border-radius: 6px;
    }

    .nav-hamburger:focus-visible {
      outline: 3px solid var(--forest);
      outline-offset: 2px;
    }

    .nav-hamburger span {
      display: block;
      width: 24px;
      height: 2px;
      background: var(--text);
      transition: transform 0.3s;
    }

    /* =========================================
       HERO
       ========================================= */
    .hero {
      padding: 140px 0 100px;
      position: relative;
      overflow: hidden;
    }

    .hero-inner {
      display: grid;
      grid-template-columns: 1fr 420px;
      gap: 60px;
      align-items: center;
    }

    .hero-label {
      font-family: var(--accent-serif);
      font-style: italic;
      font-weight: 400;
      color: var(--brass);
      font-size: 1.05rem;
      letter-spacing: 0.06em;
      margin-bottom: 16px;
    }

    .hero-title {
      font-family: var(--display);
      font-weight: 900;
      font-size: 5.5rem;
      line-height: 1.02;
      margin-bottom: 28px;
    }

    .hero-title .green { color: var(--forest); }

    .hero-subtitle {
      font-family: var(--body);
      font-weight: 300;
      font-size: 1.15rem;
      line-height: 1.7;
      color: var(--text-secondary);
      max-width: 540px;
      margin-bottom: 36px;
    }

    .hero-ctas {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
    }

    .btn-solid {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: var(--body);
      font-weight: 600;
      font-size: 0.9rem;
      letter-spacing: 0.04em;
      padding: 14px 30px;
      min-height: 44px;
      border-radius: 8px;
      border: none;
      cursor: pointer;
      transition: all 0.3s;
    }

    .btn-green {
      background: var(--forest);
      color: var(--white);
    }

    .btn-green:hover { background: #1e2d1f; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(44,62,45,0.25); }

    .btn-solid:focus-visible {
      outline: 3px solid var(--brass);
      outline-offset: 3px;
    }

    .btn-outline {
      background: transparent;
      color: var(--brass);
      border: 1.5px solid var(--brass);
      padding: 13px 30px;
      min-height: 44px;
    }

    .btn-outline:hover { background: var(--brass); color: var(--white); transform: translateY(-2px); }

    /* Stats Card */
    .hero-stats-card {
      background: var(--forest);
      color: var(--white);
      border-radius: 16px;
      padding: 40px 36px;
      transform: perspective(800px) rotateY(-6deg) rotateX(3deg);
      box-shadow: 24px 24px 60px rgba(44, 62, 45, 0.3), -4px -4px 20px rgba(201, 169, 110, 0.08);
      position: relative;
      transition: transform 0.4s;
    }

    .hero-stats-card:hover {
      transform: perspective(800px) rotateY(-2deg) rotateX(1deg);
    }

    .stats-label {
      font-family: var(--body);
      font-weight: 600;
      font-size: 0.8rem;
      letter-spacing: 0.15em;
      color: var(--brass);
      margin-bottom: 28px;
    }

    .stats-row {
      display: flex;
      gap: 24px;
      margin-bottom: 32px;
    }

    .stat-item {
      text-align: center;
      flex: 1;
    }

    .stat-number {
      font-family: var(--display);
      font-weight: 900;
      font-size: 2rem;
      color: var(--white);
      line-height: 1;
    }

    .stat-label-text {
      font-family: var(--body);
      font-weight: 400;
      font-size: 0.8rem;
      letter-spacing: 0.06em;
      color: rgba(255,255,255,0.85);
      margin-top: 6px;
    }

    .stats-divider {
      width: 1px;
      background: rgba(201, 169, 110, 0.3);
    }

    .stats-pills {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .stats-pill {
      font-family: var(--body);
      font-weight: 500;
      font-size: 0.8rem;
      letter-spacing: 0.04em;
      padding: 6px 14px;
      border-radius: 20px;
      background: rgba(201, 169, 110, 0.2);
      color: var(--brass);
      border: 1px solid rgba(201, 169, 110, 0.4);
    }

    /* 3D Decorative elements */
    .hero-decor {
      position: absolute;
      pointer-events: none;
    }

    .decor-square {
      width: 80px;
      height: 80px;
      border: 1.5px solid var(--brass);
      position: absolute;
      opacity: 0.18;
    }

    .decor-square-1 {
      top: 120px; right: 60px;
      transform: rotate(35deg);
    }

    .decor-square-2 {
      bottom: 40px; right: 180px;
      width: 50px; height: 50px;
      transform: rotate(55deg);
      opacity: 0.12;
    }

    .decor-circles {
      position: absolute;
      top: 80px; left: -40px;
      opacity: 0.08;
    }

    .decor-circles circle {
      fill: none;
      stroke: var(--brass);
      stroke-width: 1;
    }

    /* =========================================
       CORE SKILLS
       ========================================= */
    .skills {
      padding: 100px 0;
    }

    .skills-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-top: 48px;
    }

    .skill-card {
      background: var(--white);
      border-radius: 14px;
      padding: 36px 30px;
      transition: transform 0.3s, box-shadow 0.3s;
      cursor: default;
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(0,0,0,0.04);
    }

    .skill-card:hover {
      transform: perspective(600px) rotateY(-3deg) translateY(-4px);
      box-shadow: 12px 12px 40px rgba(0,0,0,0.08);
    }

    .skill-card.dark {
      background: var(--forest);
      color: var(--white);
      border-color: transparent;
    }

    .skill-card.dark .skill-techs { color: rgba(255,255,255,0.85); }
    .skill-card.dark .skill-title { color: var(--white); }

    .skill-card.black {
      background: var(--black);
      color: var(--white);
      border-color: transparent;
    }

    .skill-card.black .skill-techs { color: rgba(255,255,255,0.82); }
    .skill-card.black .skill-title { color: var(--white); }

    .skill-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 20px;
      font-size: 1.3rem;
    }

    .skill-icon.green-bg { background: rgba(44, 62, 45, 0.1); color: var(--forest); }
    .skill-icon.brass-bg { background: rgba(201, 169, 110, 0.15); color: var(--brass); }
    .skill-icon.terra-bg { background: rgba(212, 97, 58, 0.12); color: var(--terracotta); }
    .skill-icon.white-bg { background: rgba(255,255,255,0.12); color: var(--white); }
    .skill-icon.brass-light-bg { background: rgba(201, 169, 110, 0.12); color: var(--brass); }

    .skill-title {
      font-family: var(--display);
      font-weight: 800;
      font-size: 1.3rem;
      margin-bottom: 10px;
      color: var(--text);
    }

    .skill-techs {
      font-family: var(--body);
      font-weight: 300;
      font-size: 0.88rem;
      line-height: 1.7;
      color: var(--text-secondary);
    }

    .skill-bar {
      position: absolute;
      bottom: 0;
      left: 30px;
      right: 30px;
      height: 3px;
      border-radius: 2px;
    }

    .skill-bar.brass { background: var(--brass); }
    .skill-bar.green { background: var(--forest); }
    .skill-bar.terra { background: var(--terracotta); }
    .skill-bar.white-bar { background: rgba(255,255,255,0.3); }

    /* =========================================
       PROJECTS
       ========================================= */
    .projects {
      padding: 100px 0;
    }

    .project-featured {
      display: grid;
      grid-template-columns: 1fr 1fr;
      border-radius: 16px;
      overflow: hidden;
      margin-top: 48px;
      min-height: 380px;
      transition: transform 0.3s, box-shadow 0.3s;
    }

    .project-featured:hover {
      transform: perspective(800px) rotateY(-1.5deg) translateY(-4px);
      box-shadow: 16px 16px 48px rgba(0,0,0,0.1);
    }

    .project-featured-content {
      background: var(--forest);
      color: var(--white);
      padding: 48px 40px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .project-featured-visual {
      background: var(--black);
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }

    .project-featured-visual svg {
      opacity: 0.15;
    }

    .project-tags {
      display: flex;
      gap: 8px;
      margin-bottom: 16px;
      flex-wrap: wrap;
    }

    .project-tag {
      font-family: var(--body);
      font-weight: 500;
      font-size: 0.8rem;
      letter-spacing: 0.05em;
      padding: 5px 12px;
      border-radius: 16px;
      background: rgba(201, 169, 110, 0.18);
      color: var(--brass);
    }

    .project-tag.dark-tag {
      background: rgba(255,255,255,0.12);
      color: rgba(255,255,255,0.9);
    }

    .project-title {
      font-family: var(--display);
      font-weight: 900;
      font-size: 2rem;
      margin-bottom: 12px;
    }

    .project-desc {
      font-family: var(--body);
      font-weight: 400;
      font-size: 0.95rem;
      line-height: 1.7;
      color: rgba(255,255,255,0.88);
      margin-bottom: 20px;
    }

    .project-link {
      font-family: var(--body);
      font-weight: 600;
      font-size: 0.85rem;
      color: var(--brass);
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: gap 0.3s;
    }

    .project-link:hover { gap: 12px; }

    .project-link:focus-visible {
      outline: 3px solid var(--brass);
      outline-offset: 2px;
      border-radius: 2px;
    }

    .projects-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      margin-top: 24px;
    }

    .project-card {
      border-radius: 14px;
      padding: 36px 30px;
      transition: transform 0.3s, box-shadow 0.3s;
      cursor: default;
      position: relative;
      border: 1px solid rgba(0,0,0,0.04);
    }

    .project-card:hover {
      transform: perspective(600px) rotateY(-2deg) translateY(-4px);
      box-shadow: 12px 12px 40px rgba(0,0,0,0.08);
    }

    .project-card.light { background: var(--white); }
    .project-card.dark { background: var(--forest); color: var(--white); border-color: transparent; }
    .project-card.dark .project-desc { color: rgba(255,255,255,0.85); }
    .project-card.black { background: var(--black); color: var(--white); border-color: transparent; }
    .project-card.black .project-desc { color: rgba(255,255,255,0.82); }
    .project-card.light .project-desc { color: var(--text-secondary); }
    .project-card.light .project-title { color: var(--text); }

    /* =========================================
       CLAUDE CODE SECTION
       ========================================= */
    .claude-section {
      padding: 100px 0;
      background: var(--forest);
      color: var(--white);
      position: relative;
    }

    .claude-section .section-title { color: var(--white); }

    .claude-desc {
      font-family: var(--body);
      font-weight: 400;
      font-size: 1.05rem;
      line-height: 1.7;
      color: rgba(255,255,255,0.88);
      max-width: 640px;
      margin-bottom: 48px;
    }

    .claude-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }

    .claude-card {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(201, 169, 110, 0.12);
      border-radius: 14px;
      padding: 32px 26px;
      transition: transform 0.3s, background 0.3s, box-shadow 0.3s;
    }

    .claude-card:hover {
      background: rgba(255,255,255,0.1);
      transform: perspective(600px) rotateY(-2deg) translateY(-4px);
      box-shadow: 0 12px 40px rgba(0,0,0,0.2);
    }

    .claude-card-graphic {
      width: 100%;
      margin-bottom: 16px;
      border-radius: 10px;
      overflow: hidden;
      background: rgba(0,0,0,0.08);
      padding: 8px 0;
    }

    .claude-card-graphic svg {
      width: 100%;
      height: auto;
    }

    .claude-card-icon {
      width: 52px;
      height: 52px;
      border-radius: 12px;
      background: rgba(201, 169, 110, 0.12);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 20px;
    }

    .claude-card-icon svg {
      width: 26px;
      height: 26px;
      stroke: var(--brass);
      fill: none;
      stroke-width: 1.5;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .claude-card-title {
      font-family: var(--display);
      font-weight: 800;
      font-size: 1.15rem;
      margin-bottom: 10px;
      color: var(--white);
    }

    .claude-card-desc {
      font-family: var(--body);
      font-weight: 400;
      font-size: 0.9rem;
      line-height: 1.65;
      color: rgba(255,255,255,0.85);
    }

    /* =========================================
       TOOLS BAR
       ========================================= */
    .tools-bar {
      padding: 60px 0;
      border-top: 1px solid rgba(201, 169, 110, 0.15);
      border-bottom: 1px solid rgba(201, 169, 110, 0.15);
    }

    .tools-inner {
      display: flex;
      justify-content: center;
      gap: 64px;
      flex-wrap: wrap;
    }

    .tool-group {
      text-align: center;
    }

    .tool-group-label {
      font-family: var(--body);
      font-weight: 600;
      font-size: 0.8rem;
      letter-spacing: 0.12em;
      color: var(--brass);
      margin-bottom: 10px;
    }

    .tool-group-items {
      font-family: var(--body);
      font-weight: 300;
      font-size: 0.88rem;
      color: var(--text-secondary);
    }

    /* =========================================
       SHOPIFY SOLUTIONS
       ========================================= */
    .shopify-section {
      padding: 100px 0;
      background: linear-gradient(180deg, var(--bg) 0%, #EDE7DF 100%);
      position: relative;
    }

    .shopify-section::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, var(--terracotta), var(--brass), var(--forest));
    }

    .shopify-lead {
      font-family: var(--body);
      font-weight: 300;
      font-size: 1.15rem;
      line-height: 1.75;
      color: var(--text-secondary);
      max-width: 680px;
      margin-bottom: 56px;
    }

    .shopify-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-bottom: 56px;
    }

    .shopify-card {
      background: var(--white);
      border-radius: 16px;
      padding: 36px 30px;
      border: 1px solid rgba(0,0,0,0.04);
      box-shadow: 0 4px 20px rgba(0,0,0,0.04);
      transition: transform 0.3s, box-shadow 0.3s;
      position: relative;
    }

    .shopify-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 12px 40px rgba(0,0,0,0.1);
    }

    .shopify-card-number {
      font-family: var(--display);
      font-weight: 900;
      font-size: 3rem;
      color: rgba(212, 97, 58, 0.08);
      position: absolute;
      top: 16px;
      right: 24px;
      line-height: 1;
    }

    .shopify-card-title {
      font-family: var(--display);
      font-weight: 800;
      font-size: 1.2rem;
      color: var(--text);
      margin-bottom: 12px;
    }

    .shopify-card-problem {
      font-family: var(--accent-serif);
      font-style: italic;
      font-weight: 400;
      font-size: 0.95rem;
      color: var(--terracotta);
      margin-bottom: 14px;
      line-height: 1.5;
      padding-bottom: 14px;
      border-bottom: 1px solid rgba(212, 97, 58, 0.12);
    }

    .shopify-card-solution {
      font-family: var(--body);
      font-weight: 400;
      font-size: 0.9rem;
      line-height: 1.65;
      color: var(--text-secondary);
    }

    .shopify-cta-row {
      text-align: center;
    }

    .shopify-cta-btn {
      display: inline-flex;
      align-items: center;
      padding: 18px 48px;
      min-height: 56px;
      background: var(--terracotta);
      color: var(--white);
      font-family: var(--body);
      font-weight: 600;
      font-size: 1rem;
      letter-spacing: 0.04em;
      border-radius: 60px;
      transition: background 0.3s, transform 0.2s;
    }

    .shopify-cta-btn:hover {
      background: #C0552F;
      transform: translateY(-2px);
    }

    .shopify-cta-btn:focus-visible {
      outline: 3px solid var(--forest);
      outline-offset: 3px;
    }

    .shopify-cta-note {
      font-family: var(--body);
      font-weight: 300;
      font-size: 0.85rem;
      color: var(--text-secondary);
      margin-top: 14px;
    }

    /* =========================================
       CREDIBILITY BAR
       ========================================= */
    .credibility {
      padding: 72px 0;
      text-align: center;
    }

    .credibility-label {
      font-family: var(--body);
      font-weight: 600;
      font-size: 0.8rem;
      letter-spacing: 0.15em;
      color: var(--text-secondary);
      margin-bottom: 36px;
    }

    .credibility-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0;
      flex-wrap: wrap;
    }

    .credibility-item {
      padding: 0 32px;
      text-align: center;
      border-right: 1px solid var(--brass);
    }

    .credibility-item:last-child { border-right: none; }

    .credibility-name {
      font-family: var(--display);
      font-weight: 800;
      font-size: 1.05rem;
      color: var(--text);
      margin-bottom: 4px;
    }

    .credibility-sub {
      font-family: var(--body);
      font-weight: 400;
      font-size: 0.8rem;
      letter-spacing: 0.08em;
      color: var(--text-secondary);
    }

    /* =========================================
       SERVICES
       ========================================= */
    .services {
      padding: 100px 0;
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-top: 48px;
    }

    .service-card {
      border-radius: 14px;
      padding: 40px 30px;
      position: relative;
      transition: transform 0.3s, box-shadow 0.3s;
      border: 1px solid rgba(0,0,0,0.04);
    }

    .service-card:hover {
      transform: translateY(-6px);
      box-shadow: 12px 12px 40px rgba(0,0,0,0.1);
    }

    .service-card.light { background: var(--white); }
    .service-card.dark { background: var(--forest); color: var(--white); border-color: transparent; }
    .service-card.black { background: var(--black); color: var(--white); border-color: transparent; }

    .service-badge {
      position: absolute;
      top: -12px;
      right: 24px;
      font-family: var(--body);
      font-weight: 700;
      font-size: 0.8rem;
      letter-spacing: 0.08em;
      padding: 6px 16px;
      border-radius: 20px;
      background: var(--brass);
      color: var(--white);
    }

    .service-type {
      font-family: var(--body);
      font-weight: 600;
      font-size: 0.8rem;
      letter-spacing: 0.08em;
      color: var(--brass);
      margin-bottom: 8px;
    }

    .service-title {
      font-family: var(--display);
      font-weight: 900;
      font-size: 1.6rem;
      margin-bottom: 6px;
    }

    .service-card.light .service-title { color: var(--text); }
    .service-card.dark .service-title { color: var(--white); }
    .service-card.black .service-title { color: var(--white); }

    .service-subtitle {
      font-family: var(--body);
      font-weight: 300;
      font-size: 0.88rem;
      color: var(--text-secondary);
      margin-bottom: 24px;
    }

    .service-card.dark .service-subtitle { color: rgba(255,255,255,0.82); }
    .service-card.black .service-subtitle { color: rgba(255,255,255,0.82); }

    .service-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .service-list li {
      font-family: var(--body);
      font-weight: 400;
      font-size: 0.85rem;
      display: flex;
      align-items: flex-start;
      gap: 10px;
      line-height: 1.5;
    }

    .service-card.dark .service-list li { color: rgba(255,255,255,0.92); }
    .service-card.black .service-list li { color: rgba(255,255,255,0.9); }

    .check-icon {
      flex-shrink: 0;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-top: 2px;
    }

    .check-icon.green { background: rgba(44, 62, 45, 0.1); color: var(--forest); }
    .check-icon.brass { background: rgba(201, 169, 110, 0.15); color: var(--brass); }
    .check-icon.terra { background: rgba(212, 97, 58, 0.15); color: var(--terracotta); }
    .check-icon.white-check { background: rgba(255,255,255,0.12); color: var(--white); }

    .check-svg { width: 10px; height: 10px; }

    /* =========================================
       INQUIRY FORM
       ========================================= */
    .inquiry {
      padding: 100px 0;
    }

    .inquiry-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: start;
    }

    .inquiry-info h3 {
      font-family: var(--display);
      font-weight: 900;
      font-size: 2.8rem;
      line-height: 1.1;
      margin-bottom: 20px;
    }

    .inquiry-info p {
      font-family: var(--body);
      font-weight: 300;
      font-size: 1rem;
      color: var(--text-secondary);
      line-height: 1.7;
      margin-bottom: 32px;
    }

    .inquiry-detail {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 16px;
    }

    .inquiry-detail-icon {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      background: rgba(44, 62, 45, 0.08);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .inquiry-detail-icon svg {
      width: 18px;
      height: 18px;
      stroke: var(--forest);
      fill: none;
      stroke-width: 1.5;
    }

    .inquiry-detail-label {
      font-family: var(--body);
      font-weight: 600;
      font-size: 0.8rem;
      letter-spacing: 0.08em;
      color: var(--text-secondary);
    }

    .inquiry-detail-value {
      font-family: var(--body);
      font-weight: 400;
      font-size: 0.92rem;
      color: var(--text);
    }

    .inquiry-form-card {
      background: var(--white);
      border-radius: 16px;
      padding: 40px 36px;
      border: 1px solid rgba(0,0,0,0.04);
      box-shadow: 0 8px 32px rgba(0,0,0,0.06);
      transform: perspective(800px) rotateY(2deg);
      transition: transform 0.4s;
    }

    .inquiry-form-card:hover {
      transform: perspective(800px) rotateY(0deg);
    }

    .form-group {
      margin-bottom: 20px;
    }

    .form-label {
      display: block;
      font-family: var(--body);
      font-weight: 600;
      font-size: 0.875rem;
      letter-spacing: 0.08em;
      color: var(--text-secondary);
      margin-bottom: 8px;
    }

    .form-input,
    .form-select,
    .form-textarea {
      width: 100%;
      padding: 12px 16px;
      border: 1.5px solid rgba(0,0,0,0.15);
      border-radius: 8px;
      background: var(--bg);
      color: var(--text);
      font-family: var(--body);
      font-weight: 400;
      font-size: 1rem;
      line-height: 1.5;
      transition: border-color 0.3s, box-shadow 0.3s;
      outline: none;
      min-height: 44px;
    }

    .form-input:focus,
    .form-select:focus,
    .form-textarea:focus {
      border-color: var(--forest);
      box-shadow: 0 0 0 3px rgba(44, 62, 45, 0.15);
    }

    .form-input:focus-visible,
    .form-select:focus-visible,
    .form-textarea:focus-visible {
      border-color: var(--forest);
      box-shadow: 0 0 0 3px rgba(44, 62, 45, 0.2);
      outline: none;
    }

    .form-textarea { resize: vertical; min-height: 120px; }
    .form-select { cursor: pointer; appearance: auto; }

    .form-submit {
      width: 100%;
      padding: 14px 24px;
      min-height: 48px;
      background: var(--forest);
      color: var(--white);
      font-family: var(--body);
      font-weight: 600;
      font-size: 1rem;
      letter-spacing: 0.04em;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      transition: background 0.3s, transform 0.3s, box-shadow 0.3s;
    }

    .form-submit:hover {
      background: #1e2d1f;
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(44, 62, 45, 0.25);
    }

    .form-submit:focus-visible {
      outline: 3px solid var(--brass);
      outline-offset: 2px;
    }

    /* =========================================
       FOOTER
       ========================================= */
    .footer {
      padding: 40px 0 48px;
      position: relative;
    }

    .footer::before {
      content: '';
      position: absolute;
      top: 0; left: 24px; right: 24px;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--brass), transparent);
    }

    .footer-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 32px;
    }

    .footer-logo {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .footer-logo-circle {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: var(--forest);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--brass);
      font-family: var(--display);
      font-weight: 900;
      font-size: 0.9rem;
    }

    .footer-logo-text {
      font-family: var(--body);
      font-weight: 600;
      font-size: 0.875rem;
      letter-spacing: 0.1em;
      color: var(--text);
    }

    .footer-links {
      display: flex;
      gap: 24px;
    }

    .footer-social-link {
      color: var(--text-secondary);
      transition: color 0.3s;
      display: flex;
      align-items: center;
    }

    .footer-social-link:hover { color: var(--forest); }

    .footer-social-link:focus-visible {
      outline: 3px solid var(--forest);
      outline-offset: 4px;
      border-radius: 4px;
    }

    .footer-social-link svg {
      width: 20px;
      height: 20px;
      fill: currentColor;
    }

    .nav-logo:focus-visible {
      outline: 3px solid var(--forest);
      outline-offset: 3px;
      border-radius: 4px;
    }

    .footer-right {
      font-family: var(--body);
      font-weight: 400;
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    .footer-right a {
      color: var(--forest);
      font-weight: 500;
      transition: color 0.3s;
    }

    .footer-right a:hover { color: var(--brass); }

    /* =========================================
       RESPONSIVE
       ========================================= */
    @media (max-width: 1024px) {
      .hero-title { font-size: 4rem; }
      .hero-inner { grid-template-columns: 1fr 360px; gap: 40px; }
      .skills-grid { grid-template-columns: repeat(2, 1fr); }
      .claude-grid { grid-template-columns: repeat(2, 1fr); }
      .services-grid { grid-template-columns: repeat(2, 1fr); }
      .shopify-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-hamburger { display: flex; }

      .hero { padding: 110px 0 60px; }
      .hero-inner { grid-template-columns: 1fr; gap: 40px; }
      .hero-title { font-size: 3.2rem; }
      .hero-subtitle { font-size: 1rem; }
      .hero-stats-card {
        transform: none;
        max-width: 400px;
      }
      .hero-stats-card:hover { transform: none; }

      .section-title { font-size: 2.2rem; }

      .skills-grid { grid-template-columns: 1fr; }
      .claude-grid { grid-template-columns: 1fr; }
      .services-grid { grid-template-columns: 1fr; }
      .shopify-grid { grid-template-columns: 1fr; }
      .projects-row { grid-template-columns: 1fr; }

      .project-featured { grid-template-columns: 1fr; }
      .project-featured-visual { min-height: 200px; }

      .inquiry-inner { grid-template-columns: 1fr; gap: 40px; }
      .inquiry-form-card { transform: none; }
      .inquiry-form-card:hover { transform: none; }

      .credibility-row { flex-direction: column; gap: 20px; }
      .credibility-item { border-right: none; border-bottom: 1px solid rgba(201, 169, 110, 0.2); padding: 12px 0; }
      .credibility-item:last-child { border-bottom: none; }

      .tools-inner { gap: 32px; }

      .footer-inner { flex-direction: column; gap: 20px; text-align: center; }

      .decor-square, .decor-circles { display: none; }
    }

    @media (max-width: 480px) {
      .hero-title { font-size: 2.6rem; }
      .hero-ctas { flex-direction: column; }
      .hero-ctas .btn-solid, .hero-ctas .btn-outline { width: 100%; justify-content: center; }
      .stats-row { gap: 16px; }
      .stat-number { font-size: 1.6rem; }
    }
  </style>
</head>
